<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Signup</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
            rel="stylesheet">
        <style>
            body { font-family: 'Poppins', sans-serif; }
            .glass-card {
                background: rgba(255, 255, 255, 0.1);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.2);
            }
            .animate-gradient {
                background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
                background-size: 400% 400%;
                animation: gradient 15s ease infinite;
            }
            @keyframes gradient {
                0% { background-position: 0% 50%; }
                50% { background-position: 100% 50%; }
                100% { background-position: 0% 50%; }
            }
        </style>
    </head>

    <body class="animate-gradient min-h-screen">

        <%- include('../partials/nav') %>

        <div class="flex items-center justify-center min-h-screen px-4 py-8">
            <div
                class="glass-card bg-white/10 p-8 rounded-2xl shadow-2xl w-full max-w-md text-white">

                <!-- Header -->
                <div class="text-center mb-8">
                    <div
                        class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/20 mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg"
                            class="w-8 h-8 text-white" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor"
                            stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                        </svg>
                    </div>
                    <h2 class="text-3xl font-bold text-white mb-2">Create
                        Account</h2>
                    <p class="text-white/70 text-sm">Join us and start your
                        journey</p>
                </div>
                <%- include('../partials/errors') %>
                <form action="/signup" method="POST" class="space-y-5">

                    <!-- Name Fields Row -->
                    <div class="grid grid-cols-2 gap-4">
                        <!-- First Name -->
                        <div class="relative">
                            <label
                                class="text-xs font-medium text-white/80 ml-1 mb-1 block">First
                                Name</label>
                            <div class="relative">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                    class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                                    fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <input type="text" name="firstName"
                                    value="<%= oldInput.firstName ? oldInput.firstName : '' %>"
                                    required
                                    class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white"
                                    value="<%= oldInput ? oldInput.firstName : '' %>">
                            </div>
                        </div>

                        <!-- Last Name -->
                        <div class="relative">
                            <label
                                class="text-xs font-medium text-white/80 ml-1 mb-1 block">Last
                                Name</label>
                            <div class="relative">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                    class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                                    fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <input type="text" name="lastName"
                                    value="<%= oldInput.lastName ? oldInput.lastName : '' %>"
                                    required
                                    class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white">
                            </div>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="relative">
                        <label
                            class="text-xs font-medium text-white/80 ml-1 mb-1 block">Email
                            Address</label>
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                                fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <input type="email" name="email"
                                value="<%= oldInput.email ? oldInput.email : '' %>"
                                required
                                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white">
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="relative">
                        <label
                            class="text-xs font-medium text-white/80 ml-1 mb-1 block">Password</label>
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                                fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password" name="password" required
                                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white">
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="relative">
                        <label
                            class="text-xs font-medium text-white/80 ml-1 mb-1 block">Confirm
                            Password</label>
                        <div class="relative">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                                fill="none" viewBox="0 0 24 24"
                                stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            <input type="password" name="conformPassword"
                                required
                                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white">
                        </div>
                    </div>

                    <!-- User Type -->
                    <div class="mb-5">
                        <p
                            class="text-xs font-medium text-white/80 ml-1 mb-3 block">I
                            want to register as:</p>
                        <div class="grid grid-cols-2 gap-4">
                            <!-- Guest Option -->
                            <label class="cursor-pointer relative">
                                <input type="radio" name="userType"
                                    value="guest" id="guest"
                                    class="peer sr-only"
                                    <% if (!oldInput.userType ||
                                    oldInput.userType === 'guest') {
                                    %>checked<% } %> />
                                <div
                                    class="p-4 rounded-xl bg-white/5 border border-white/20 peer-checked:bg-pink-500/30 peer-checked:border-pink-400 peer-checked:shadow-lg peer-checked:shadow-pink-500/20 transition-all duration-300 hover:bg-white/10 text-center">
                                    <div class="flex flex-col items-center">
                                        <div
                                            class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-2 peer-checked:bg-pink-500/50 transition-all duration-300">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="w-6 h-6 text-white/80 peer-checked:text-white"
                                                fill="none" viewBox="0 0 24 24"
                                                stroke="currentColor"
                                                stroke-width="2">
                                                <path stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                            </svg>
                                        </div>
                                        <span
                                            class="text-sm font-medium text-white/80 peer-checked:text-white peer-checked:font-semibold">Guest</span>
                                        <span
                                            class="text-xs text-white/50 mt-1">Book
                                            & stay</span>
                                    </div>
                                </div>
                            </label>

                            <!-- Host Option -->
                            <label class="cursor-pointer relative">
                                <input type="radio" name="userType" value="host"
                                    id="host" class="peer sr-only"
                                    <% if (oldInput.userType === 'host') {
                                    %>checked<% } %> />
                                <div
                                    class="p-4 rounded-xl bg-white/5 border border-white/20 peer-checked:bg-pink-500/30 peer-checked:border-pink-400 peer-checked:shadow-lg peer-checked:shadow-pink-500/20 transition-all duration-300 hover:bg-white/10 text-center">
                                    <div class="flex flex-col items-center">
                                        <div
                                            class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-2 peer-checked:bg-pink-500/50 transition-all duration-300">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="w-6 h-6 text-white/80 peer-checked:text-white"
                                                fill="none" viewBox="0 0 24 24"
                                                stroke="currentColor"
                                                stroke-width="2">
                                                <path stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                            </svg>
                                        </div>
                                        <span
                                            class="text-sm font-medium text-white/80 peer-checked:text-white peer-checked:font-semibold">Host</span>
                                        <span
                                            class="text-xs text-white/50 mt-1">List
                                            your home</span>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Terms -->
                    <div class="flex items-center space-x-3">
                        <input type="checkbox" name="terms" required
                            class="w-4 h-4 rounded border-white/30 bg-white/10 text-pink-500 focus:ring-pink-400 focus:ring-offset-0 cursor-pointer">
                        <label class="text-sm text-white/80">I agree to the
                            <a href="#"
                                class="text-pink-400 hover:text-pink-300 underline">Terms
                                & Conditions</a>
                        </label>
                    </div>

                    <!-- Button -->
                    <button type="submit"
                        class="w-full bg-gradient-to-r from-pink-500 via-red-500 to-yellow-500 hover:from-pink-600 hover:via-red-600 hover:to-yellow-600 transition-all duration-300 py-3 rounded-xl font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                        Create Account
                    </button>

                    <!-- Login Link -->
                    <p class="text-center text-white/70 text-sm">
                        Already have an account?
                        <a href="/login"
                            class="text-pink-400 hover:text-pink-300 font-medium">Login</a>
                    </p>

                </form>

            </div>
        </div>
    </body>
</html>
