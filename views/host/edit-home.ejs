<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= editing ? "Edit" : "Register"%> Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }
      .animate-gradient {
        background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
        background-size: 400% 400%;
        animation: gradient 15s ease infinite;
      }
      @keyframes gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }
    </style>
  </head>

  <body class="bg-black text-white">
    
    <!-- 🔥 LOADER -->

    <%- include('../partials/loder') %>
    
    <!-- 🔥 MAIN CONTENT -->
    <div id="content" style="display:none;" class="flex flex-col min-h-screen">
    <%- include('../partials/nav') %>

    <main class="container mx-auto mt-8 p-8">
      <div
        class="glass-card bg-white/10 p-8 rounded-2xl shadow-2xl w-full max-w-2xl mx-auto">

        <!-- Header -->
        <div class="text-center mb-8">
          <div
            class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/20 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white"
              fill="none" viewBox="0 0 24 24" stroke="currentColor"
              stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-white mb-2"><%= editing ? "Edit" :
            "Register"%> Your Home on AirBnB</h1>
          <p class="text-white/70 text-sm"><%= editing ?
            "Update your property details" : "List your property for guests"
            %></p>
        </div>

        <form action="/host/<%= editing ? "edit-home" : "add-home"%>"
          method="POST" enctype="multipart/form-data" class="space-y-5">
          <input type="hidden" name="id"
            value="<%= editing ? home._id : ''%>" />

          <!-- House Name -->
          <div class="relative">
            <label
              class="text-xs font-medium text-white/80 ml-1 mb-1 block">House
              Name</label>
            <div class="relative">
              <svg xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                fill="none" viewBox="0 0 24 24" stroke="currentColor"
                stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              <input type="text" name="houseName"
                value="<%= editing ? home.houseName : ''%>"
                placeholder="Enter your House Name"
                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white"
                required />
            </div>
          </div>

          <!-- Price and Rating Row -->
          <div class="grid grid-cols-2 gap-4">
            <!-- Price -->
            <div class="relative">
              <label
                class="text-xs font-medium text-white/80 ml-1 mb-1 block">Price
                Per Night</label>
              <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor"
                  stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <input type="text" name="price"
                  value="<%= editing ? home.price : ''%>"
                  placeholder="Price Per Night"
                  class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white"
                  required />
              </div>
            </div>

            <!-- Rating -->
            <div class="relative">
              <label
                class="text-xs font-medium text-white/80 ml-1 mb-1 block">Rating</label>
              <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor"
                  stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                <input type="text" name="rating"
                  value="<%= editing ? home.rating : ''%>" placeholder="Rating"
                  class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white"
                  required />
              </div>
            </div>
          </div>

          <!-- Location -->
          <div class="relative">
            <label
              class="text-xs font-medium text-white/80 ml-1 mb-1 block">Location</label>
            <div class="relative">
              <svg xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                fill="none" viewBox="0 0 24 24" stroke="currentColor"
                stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <input type="text" name="location"
                value="<%= editing ? home.location : ''%>"
                placeholder="Location"
                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white"
                required />
            </div>
          </div>

          <!-- Photo URL -->
          <div class="relative">
            <label
              class="text-xs font-medium text-white/80 ml-1 mb-1 block">Photo
              URL</label>
            <div class="relative">
              <svg xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-pink-400"
                fill="none" viewBox="0 0 24 24" stroke="currentColor"
                stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <input type="file" name="photo" accept="images/jpg, images/png"
                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white" />
            </div>
          </div>

          <!-- Description -->
          <div class="relative">
            <label
              class="text-xs font-medium text-white/80 ml-1 mb-1 block">Description</label>
            <div class="relative">
              <svg xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 absolute left-3 top-3 text-pink-400" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M4 6h16M4 12h16M4 18h7" />
              </svg>
              <textarea name="description" placeholder="Describe your home"
                rows="4"
                class="w-full pl-10 pr-4 py-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent transition-all duration-300 placeholder-white/40 text-white resize-none"><%= editing ? home.description : ''%></textarea>
            </div>
          </div>

          <!-- Submit Button -->
          <button type="submit" value="<%= editing ? " Update Home" :
            "Add Home"%>"
            class="w-full bg-gradient-to-r from-pink-500 via-red-500 to-yellow-500 hover:from-pink-600 hover:via-red-600 hover:to-yellow-600 transition-all duration-300 py-3 rounded-xl font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
            <%= editing ? "Update Home" : "Add Home"%>
          </button>
        </form>
      </div>
    </main>
    
    <%- include('../partials/Footer') %>
    </div>
  </body>
</html>
