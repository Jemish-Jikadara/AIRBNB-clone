<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb - Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">

    <style>
    body { font-family: 'Poppins', sans-serif; }
    .glass-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); }
    .animate-gradient { background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab); background-size: 400% 400%; animation: gradient 15s ease infinite; }
    @keyframes gradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  </style>
  </head>

  <body class="bg-black text-white">

    <%- include('../partials/nav') %>

    <main class="container mx-auto p-4 sm:p-6 md:p-8 mt-10 max-w-6xl">

      <!-- SEARCH INPUT -->
      <input
        type="text"
        id="searchInput"
        placeholder="Search location (e.g Surat)"
        class="w-full p-3 rounded-lg mb-6 outline-none text-black" />

      <div class="glass-card bg-white/10 rounded-2xl shadow-2xl p-8">

        <% if (registeredHomes && registeredHomes.length > 0) { %>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

          <% registeredHomes.forEach(home => { %>

          <!--  IMPORTANT: data-location -->
          <div
            class="card glass-card bg-white/10 rounded-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2"
            data-location="<%= home.location %>">

            <div class="relative h-48 overflow-hidden">
              <img src="<%= home.photo %>" class="w-full h-full object-cover">
            </div>

            <div class="p-5">
              <h3 class="text-lg font-semibold text-white mb-2"><%=
                home.houseName %></h3>

              <p class="text-white/70 mb-4">
                📍 <%= home.location %>
              </p>

              <div class="flex justify-between items-center mb-4">
                <span class="text-xl font-bold text-yellow-300">Rs <%=
                  home.price %></span>
                <span class="text-white/60 text-sm">/ night</span>
              </div>
              <% if(isLoggedIn) { %>
              <a href="/homes/<%= home._id %>"
                class="block w-full bg-green-500 text-white py-2 rounded text-center">
                Book Now
              </a>
              <% }else{ %>
              <a href="/login"
                class="block w-full bg-green-500 text-white py-2 rounded text-center">
                Book Now
              </a>
              <% } %>
            </div>

          </div>

          <% }) %>

        </div>

        <% } else { %>

        <p class="text-white text-center">No homes found</p>

        <% } %>

      </div>
    </main>

    <%- include('../partials/Footer') %>
    <!-- SEARCH SCRIPT -->
    <script>
const input = document.getElementById("searchInput");
const cards = document.querySelectorAll(".card");

input.addEventListener("keyup", function() {
  const value = input.value.toLowerCase();

  cards.forEach(function(card) {
    const location = card.getAttribute("data-location").toLowerCase();

    if (location.includes(value)) {
      card.style.display = "block";
    } else {
      card.style.display = "none";
    }
  });
});
</script>

  </body>
</html>