<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Homes</title>
    <script src="https://cdn.tailwindcss.com"></script>

  </head>

  <body class="bg-black text-white flex flex-col min-h-screen">

    <!-- 🔥 LOADER -->

    <%- include('../partials/loder') %>

    <!-- 🔥 MAIN CONTENT -->
    <div id="content" style="display:none;" class="flex flex-col min-h-screen">

      <!-- ✅ NAVBAR -->
      <%- include('../partials/nav') %>

      <!-- ✅ MAIN -->
      <main class="container mx-auto p-6 flex-grow">

        <!-- 🔍 SEARCH -->
        <div class="relative mb-6">
          <input
            type="text"
            id="searchInput"
            placeholder="Search location (e.g Surat)"
            class="w-full p-3 pl-10 rounded-lg text-black outline-none">
          <span class="absolute left-3 top-3 text-gray-500">🔍</span>
        </div>

        <% if (registeredHomes && registeredHomes.length > 0) { %>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

          <% registeredHomes.forEach(home => { %>

          <div class="card bg-gray-800 p-4 rounded-lg"
            data-location="<%= home.location %>">

            <img src="<%= home.photo %>"
              class="w-full h-40 object-cover rounded">

            <h3 class="text-lg font-bold mt-2"><%= home.houseName %></h3>

            <p>📍 <%= home.location %></p>

            <p class="text-yellow-400">₹ <%= home.price %></p>

            <div class="flex gap-2 mt-3">
              <a href="/homes/<%= home._id %>"
                class="bg-blue-500 px-3 py-1 rounded">
                Details
              </a>

              <%- include('../partials/favourite', {home: home}) %>
            </div>

          </div>

          <% }) %>

        </div>

        <% } else { %>

        <p>No homes available</p>

        <% } %>

      </main>

      <!-- ✅ FOOTER -->
      <%- include('../partials/Footer') %>

    </div>

    <!-- 🔥 SCRIPT -->
    <script>

// 🔍 SEARCH
const input = document.getElementById("searchInput");
const cards = document.querySelectorAll(".card");

input.addEventListener("keyup", function() {
  const value = input.value.toLowerCase();

  cards.forEach(function(card) {
    const location = card.getAttribute("data-location").toLowerCase();

    if (location.includes(value)) {
      card.style.display = "block";
    } else {
      card.style.display = "none";
    }
  });
});



</script>

  </body>
</html>