<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Homes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">
    <style>
    body { font-family: 'Poppins', sans-serif; }
    .glass-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); }
    .animate-gradient { background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab); background-size: 400% 400%; animation: gradient 15s ease infinite; }
    @keyframes gradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  </style>
  </head>
  <body class="animate-gradient min-h-screen">
    <%- include('../partials/nav') %>
    <main class="container mx-auto p-4 sm:p-6 md:p-8 mt-10 max-w-6xl">
      <div class="glass-card bg-white/10 rounded-2xl shadow-2xl p-8">
        <div class="text-center mb-8">
          <div
            class="inline-flex items-center justify-center w-12 h-12 sm:w-16 sm:h-16 rounded-full bg-white/20 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white"
              fill="none" viewBox="0 0 24 24" stroke="currentColor"
              stroke-width="2"><path stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          </div>
          <h2
            class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-2">Here
            are our registered
            homes:</h2>
          <p class="text-white/70 text-xs sm:text-sm">Browse and find your
            perfect stay</p>
        </div>
        <% if (registeredHomes && registeredHomes.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% registeredHomes.forEach(home => { %>
          <div
            class="glass-card bg-white/10 rounded-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="relative h-48 overflow-hidden">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>"
                class="w-full h-full object-cover">
              <div class="absolute top-3 right-3">
                <span
                  class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-white text-xs font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 inline mr-1 text-yellow-400"
                    fill="currentColor" viewBox="0 0 24 24"><path
                      d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
                  <%= home.rating %>
                </span>
              </div>
            </div>
            <div class="p-5">
              <h3
                class="text-lg sm:text-xl font-semibold text-white mb-2 truncate"><%=
                home.houseName %></h3>
              <p
                class="text-white/70 mb-4 flex items-center text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 mr-1 text-pink-400" fill="none"
                  viewBox="0 0 24 24" stroke="currentColor"
                  stroke-width="2"><path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path
                    stroke-linecap="round" stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <%= home.location %>
              </p>
              <div class="flex justify-between items-center mb-4">
                <span
                  class="text-xl sm:text-2xl font-bold bg-gradient-to-r from-pink-500 via-red-500 to-yellow-500 bg-clip-text text-transparent">Rs
                  <%= home.price %></span>
                <span class="text-white/60 text-sm">/ night</span>
              </div>
              <div class="flex gap-2">
                <a href="/homes/<%= home._id %>"
                  class="flex-1 bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white py-2 px-3 sm:px-4 rounded-xl text-center font-medium transition-all duration-300 transform hover:scale-105">Details</a>
                <%- include('../partials/favourite', {home: home}) %>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="text-center py-12">
          <div
            class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-white/20 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white"
              fill="none" viewBox="0 0 24 24" stroke="currentColor"
              stroke-width="2"><path stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">No Homes Available</h3>
          <p class="text-white/70 mb-6">Check back later for available
            properties</p>
        </div>
        <% } %>
      </div>
    </main>
  </body>
</html>
