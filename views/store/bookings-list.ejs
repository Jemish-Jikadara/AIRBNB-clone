<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookings</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap"
      rel="stylesheet">

    <style>
    body { font-family: 'Poppins', sans-serif; }
  </style>
  </head>

  <body class="bg-black text-white">

    <!-- NAVBAR -->
    <%- include('../partials/nav') %>

    <main class="container mx-auto p-6 mt-10 max-w-7xl">

      <!-- HEADER -->
      <div class="text-center mb-10">
        <h1 class="text-4xl font-bold">Your Bookings 🏠</h1>
        <p class="text-white/60 mt-2">Manage your booked homes</p>
      </div>

      <% if (bookings && bookings.length > 0) { %>

      <!-- GRID -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <% bookings.forEach(item => { %>
        <% let home = item.homeId; %>

        <div
          class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition duration-300 hover:-translate-y-2">

          <!-- IMAGE -->
          <div class="relative h-48 overflow-hidden">
            <img src="<%= home.photo %>"
              class="w-full h-full object-cover hover:scale-110 transition duration-500">

            <!-- STATUS -->
            <div class="absolute top-3 right-3">
              <% if (item.status === "confirmed") { %>
              <span class="bg-green-500 px-3 py-1 rounded-full text-xs">✅
                Confirmed</span>
              <% } else { %>
              <span class="bg-yellow-500 px-3 py-1 rounded-full text-xs">⏳
                Pending</span>
              <% } %>
            </div>
          </div>

          <!-- CONTENT -->
          <div class="p-5">

            <h2 class="text-xl font-semibold mb-1 truncate"><%= home.houseName
              %></h2>

            <p class="text-white/60 text-sm mb-2">📍 <%= home.location %></p>

            <div class="flex justify-between items-center mb-4">
              <span class="text-2xl font-bold text-pink-400">₹ <%= home.price
                %></span>
              <span class="text-white/50 text-sm">/ night</span>
            </div>

            <!-- BUTTONS -->
            <div class="flex flex-col gap-2">

              <!-- CONFIRM -->
              <% if (item.status !== "confirmed") { %>
              <form action="/bookings/confirm/<%= home._id %>" method="POST">
                <button
                  class="w-full bg-green-500 hover:bg-green-600 py-2 rounded-xl transition transform hover:scale-105">
                  Confirm Booking
                </button>
              </form>
              <% } %>

              <!-- REMOVE -->
              <form action="/bookings/delete/<%= home._id %>" method="POST">
                <button
                  class="w-full bg-red-500 hover:bg-red-600 py-2 rounded-xl transition transform hover:scale-105">
                  Remove Booking
                </button>
              </form>

            </div>

          </div>

        </div>
        <% }) %>

      </div>

      <% } else { %>

      <!-- EMPTY STATE -->
      <div class="text-center py-20">
        <h2 class="text-3xl font-bold mb-2">No Bookings Yet 😢</h2>
        <p class="text-white/60 mb-6">Start booking your dream homes</p>

        <a href="/homes"
          class="bg-gradient-to-r from-pink-500 via-red-500 to-yellow-500 px-6 py-3 rounded-xl font-semibold hover:scale-105 transition">
          Browse Homes
        </a>
      </div>

      <% } %>

    </main>

    <!-- FOOTER -->
    <%- include('../partials/Footer') %>

  </body>
</html>